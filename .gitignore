# ============================================================
#  GhostPipe — .gitignore
# ============================================================

# --- Secrets & Config ---
.env
*.pem
*.key

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads_temp/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
pip-wheel-metadata/

# --- Virtual Environments ---
.venv/
venv/
env/
ENV/
.env.bak

# --- pytest / Testing ---
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# --- Jupyter ---
.ipynb_checkpoints
*.ipynb

# --- MyPy / Type Checkers ---
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/

# --- Docker ---
.dockerignore
docker-compose.override.yml

# --- Playwright ---
# Browser binaries are large and installed at runtime
playwright/.local-browsers/
test-results/
playwright-report/

# --- GhostPipe Runtime Data ---
# Downloaded files (mapped to host via Docker volume — not for Git)
downloads/

# ChromaDB local vector store (persisted via Docker volume — not for Git)
chromadb_data/

# Temporary screenshot/DOM dumps used by the LLM loop
.ghostpipe_tmp/
*.screenshot.png
*.dom_snapshot.html

# --- OS & Editor ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# --- Logs ---
*.log
logs/
data/
